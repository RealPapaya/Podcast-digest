# Environment variables for Podcast Digest
# Copy this file to .env and fill in your actual values
# 將此檔案複製為 .env 並填入實際的值

# ============================================
# 必需 / Required
# ============================================

# Get your Google Gemini API key from: https://aistudio.google.com/app/apikey
# 從此處取得：https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIzaSyD... (replace with your actual key)

# ============================================
# 可選 / Optional - Gmail 設定 / Gmail Configuration
# ============================================

# Your Gmail address
GMAIL_USER=your.email@gmail.com

# Gmail app password (16 characters with spaces)
# NOT your login password, but the "App Password" from Security settings
# 不是登入密碼，而是安全性設定中的「應用程式密碼」
GMAIL_APP_PASSWORD=abcd efgh ijkl mnop

# Recipient email address (defaults to GMAIL_USER if not set)
RECIPIENT_EMAIL=your.email@gmail.com

# ============================================
# 可選 / Optional - LINE Bot 設定 / LINE Bot Configuration
# ============================================

# LINE Messaging API Channel Access Token
# Get from: https://developers.line.biz/console
LINE_CHANNEL_ACCESS_TOKEN=eyJhbGciOiJIUzI1... (replace with your token)

# Your LINE User ID (starts with U)
# Get by calling: curl -X GET "https://api.line.me/v2/bot/followers/ids" \
#   -H "Authorization: Bearer YOUR_CHANNEL_ACCESS_TOKEN"
# Then pick your ID from the returned userIds array
LINE_USER_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
